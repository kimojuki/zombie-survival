PORT=3000
HOST=0.0.0.0
JWT_SECRET=change_me_in_real_deployments

# ── Base de données ───────────────────────────────────────────────────────────
# Production (Infomaniak / MariaDB) — défaut si .env omet DB_CLIENT
DB_CLIENT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=zombie_mobile_db

# Dev local uniquement — copier ces lignes dans .env et commenter MySQL ci-dessus
# DB_CLIENT=sqlite
# SQLITE_PATH=database/local-dev.sqlite
# En SQLite sans RCON_PASSWORD, le serveur utilise "dev" par défaut
# RCON_AUTO_ADMIN=true  — en SQLite, tous les joueurs sont admin (dev local uniquement)

# ── Logs serveur (console) ────────────────────────────────────────────────────
# Niveaux : error | warn | info | debug | trace
# debug = snapshots joueurs + combat + stats (recommandé dev)
# info  = connect/disconnect, loot, morts (recommandé prod)
# trace = aussi les moves joueurs (très verbeux)
LOG_LEVEL=debug
LOG_PLAYER_SNAPSHOT_MS=10000
LOG_SERVER_STATS_MS=60000
LOG_TICK_SUMMARY_MS=30000
LOG_SLOW_TICK_MS=80

# SERVER_ROLE=prod
# dev — réservé aux admins ; qa — checklist ; prod — public (défaut)
# Équipe Badom : dev + QA sur https://survival.badom.ch (alterner SERVER_ROLE dev/qa)
# Prod semi-prod : preview Infomaniak du pote (branche main) → ZS_PROD_URL

# URL serveur équipe (dev/QA) — défaut https://survival.badom.ch
# ZS_TEAM_URL=https://survival.badom.ch

# URL preview prod Infomaniak (à mettre sur survival.badom.ch pour le lien « Prod »)
# ZS_PROD_URL=https://3k51myccypp.preview.infomaniak.website

# Derrière Cloudflare / Infomaniak (obligatoire pour /api/servers et cookies proxy)
# TRUST_PROXY=true

# ── Console RCON admin ────────────────────────────────────────────────────────
# Doc complète : docs/RCON.md
#
# RCON_PASSWORD — active la console in-game (` ou F2) et l'API POST /api/rcon
# ADMIN_USERS   — comptes jeu admin sans mot de passe (séparés par des virgules)
#
# Exemple dev local :
# RCON_PASSWORD=dev_admin_secret
# ADMIN_USERS=alice,bob

# RCON_PASSWORD=your_secret_admin_password
# ADMIN_USERS=your_username,other_admin

# Derrière reverse proxy (Infomaniak prod ou cloudflared dev)
# TRUST_PROXY=true

# ── Auto-deploy prod (optionnel — voir docs/DEPLOY.md) ───────────────────────
# Webhook GitHub → scripts/webhook-deploy.js (alternative au cron)
# DEPLOY_WEBHOOK_SECRET=long_random_secret_here
# DEPLOY_WEBHOOK_PORT=9090
# ZOMBIE_PM2_NAME=zombie
# ZOMBIE_DEPLOY_BRANCH=master

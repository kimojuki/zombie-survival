{
  "name": "zombie-survival",
  "version": "1.0.0",
  "description": "Zombie FPS Open World - Mobile Web Multiplayer Game",
  "main": "apps/server/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node apps/server/index.js",
    "start:legacy": "node server.js",
    "dev": "npm run dev:server",
    "dev:server": "nodemon apps/server/index.js",
    "dev:client": "vite --config apps/client/vite.config.mjs --host 0.0.0.0",
    "build": "vite build --config apps/client/vite.config.mjs",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "node --test tests/*.test.mjs",
    "test:smoke": "node tests/smoke/server-health.mjs",
    "test:visual": "node tools/visual-tests/capture-fps-arm.mjs"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "socket.io": "^4.7.4",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "nodemon": "^3.0.2",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "vite": "^7.2.7"
  }
}

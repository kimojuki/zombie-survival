PORT=3000
JWT_SECRET=change_me_in_real_deployments

# Production (Infomaniak / MariaDB) — default if .env omits DB_CLIENT
DB_CLIENT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=zombie_mobile_db

# Local dev only (requires DB_CLIENT=sqlite in your local .env)
# DB_CLIENT=sqlite
# SQLITE_PATH=database/local-dev.sqlite
